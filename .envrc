watch_file flake.nix
watch_file yarn.lock

layout_dir="$(direnv_layout_dir)"
profile_path="$layout_dir/flake-profile"
mkdir -p "$layout_dir"

if ! flake_env="$(
  nix --extra-experimental-features "nix-command flakes" \
    print-dev-env \
    --profile "$profile_path" \
    "path:$PWD" \
    2>/dev/null
)"; then
  log_error "failed to load frontend flake environment"
  exit 1
fi

eval "$flake_env"
nix --extra-experimental-features "nix-command flakes" profile wipe-history --profile "$profile_path" >/dev/null 2>&1 || true
