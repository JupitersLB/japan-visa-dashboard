{
  "name": "japan-visa-dashboard",
  "version": "0.6.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "NODE_OPTIONS='-r dotenv/config -r newrelic' node .next/standalone/server.js",
    "lint": "eslint app next.config.ts",
    "lint:fix": "eslint app next.config.ts --fix",
    "test:unit": "vitest run",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@rollbar/react": "0.12.0-beta",
    "@tanstack/react-query": "5.62.8",
    "axios": "1.7.9",
    "dotenv": "16.4.7",
    "echarts": "5.5.1",
    "luxon": "3.5.0",
    "newrelic": "13.19.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-datepicker": "7.5.0",
    "react-dom": "19.2.6",
    "react-hook-form": "7.54.2",
    "react-select": "5.9.0",
    "rollbar": "2.26.4",
    "throttle-debounce": "5.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.17.0",
    "@playwright/test": "1.59.1",
    "@tanstack/react-query-devtools": "5.62.8",
    "@types/luxon": "3.4.2",
    "@types/newrelic": "9.14.7",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/throttle-debounce": "5.0.2",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "9.17.0",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.37.2",
    "globals": "15.14.0",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.1",
    "vitest": "4.1.5"
  }
}
